# --- Pesa Minha Buceta - Environment Variables Example ---
# Renomeie este arquivo para .env e preencha os valores abaixo

# Token do @BotFather
BOT_TOKEN=123456789:AAExemploDeTokenAqui

# Seu ID do Telegram (dono do bot)
ALLOWED_USER_ID=0

# ID do grupo de Zero Cooldown (Opcional)
GOD_MODE_GROUP_ID=0

# ID do grupo de dev/staging (Opcional)
DEV_GROUP_ID=0

# Ambiente (prod/dev)
ENV=prod
PYTHONDONTWRITEBYTECODE=1
